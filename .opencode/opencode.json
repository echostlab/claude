          "aws *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "python3 *": "allow",
          "pip3 *": "allow",
          "python *": "allow",
          "pip *": "allow",
          "docker *": "allow",
          "*": "allow"
        }
      }
    },
    "research": {
      "model": "azure-foundry/gpt-5.4",
      "temperature": 0.3,
      "reasoningEffort": "medium",
      "attachment": true,
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep_*": "allow",
        "webfetch": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api --method GET *": "allow",
