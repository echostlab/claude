{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "model": "azure-foundry/gpt-5.4",
  "autoupdate": true,
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": ["ts", "tsx", "js", "jsx", "mjs", "cjs"]
    },
    "python": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": ["py", "pyi"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": ["sh", "bash", "zsh"]
    }
  },
  "experimental": {
    "primary_tools": ["lsp"]
  },
  "formatter": {
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": ["py", "pyi"]
    },
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": ["js", "jsx", "ts", "tsx", "json", "md", "html", "css", "yaml"]
    }
  },
  "provider": {
    "azure-foundry": {
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:AZURE_OPENAI_API_KEY1}",
        "baseURL": "https://opens6505134568.openai.azure.com/openai/v1/"
      },
      "models": {
        "gpt-5.4-pro": {
          "name": "GPT 5.4-pro (Azure)",
          "attachment": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "parallelToolCalls": true
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (Azure)",
          "attachment": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "parallelToolCalls": true
          }
        },
        "FW-DeepSeek-V4-Pro": {
          "name": "FW-DeepSeek-V4-Pro",
          "attachment": true
        }
      }
    }
  },
  "permission": {
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "write": "allow",
    "bash": "allow",
    "patch": "allow",
    "lsp": "allow",
    "question": "deny",
    "task": "deny",
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep_*": "deny",
    "kagi_*": "deny",
    "webfetch": "deny",
    "worktree_*": "deny"
  },
  "agent": {
    "code-review": {
      "model": "azure-foundry/gpt-5.4",
      "temperature": 0.3,
      "attachment": true,
      "reasoningEffort": "medium",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "git --no-pager status*": "allow",
          "git --no-pager diff*": "allow",
          "git --no-pager log*": "allow",
          "git --no-pager show*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "npm *": "allow",
          "aws *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "python3 *": "allow",
          "pip3 *": "allow",
          "python *": "allow",
          "pip *": "allow",
          "docker *": "allow",
          "*": "allow"
        }
      }
    },
    "configure-opencode": {
      "model": "azure-foundry/gpt-5.4",
      "temperature": 0.3,
      "attachment": true,
      "reasoningEffort": "medium",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "opencode mcp list*": "allow",
          "opencode mcp show*": "allow",
          "opencode mcp validate*": "allow",
          "opencode mcp reload*": "allow",
          "opencode mcp status*": "allow",
          "jq *": "allow",
          "python -m json.tool *": "allow",
          "npm *": "allow",
          "aws *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "python3 *": "allow",
          "pip3 *": "allow",
          "python *": "allow",
          "pip *": "allow",
          "docker *": "allow",
          "*": "allow"
        }
      }
    },
    "explore": {
      "model": "azure-foundry/gpt-5.4",
      "temperature": 0.3,
      "attachment": true,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "allow",
          "ls *": "allow",
          "tree *": "allow",
          "pwd": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "grep *": "allow",
