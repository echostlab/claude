          "pip *": "allow",
          "docker *": "allow",
          "*": "allow"
        }
      }
    },
    "task": {
      "model": "azure-foundry/gpt-5.4",
      "temperature": 0.3,
      "reasoningEffort": "medium",
      "attachment": true,
      "permission": {
        "task": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "rg *": "allow",
          "npm run test*": "allow",
          "npm run build*": "allow",
          "npm run lint*": "allow",
          "npm run format*": "allow",
          "npm run check*": "allow",
